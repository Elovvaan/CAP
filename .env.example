# CAP environment template
# Local desktop defaults work without this file.

# Required once for first founder/admin account initialization.
# Use a real email and a strong one-time password in Railway variables.
# CAP_FOUNDER_EMAIL=founder@example.com
# CAP_FOUNDER_PASSWORD=change-this-before-first-run

# Railway sets PORT automatically. Local fallback is 1420.
# PORT=3000

# Runtime mode.
# NODE_ENV=production

# Hosted deployments should bind all interfaces. Local fallback is 127.0.0.1.
# CAP_HOST=0.0.0.0

# Persistent data directory. On Railway, set this to the volume mount path.
# CAP_DATA_DIR=/data

# Optional explicit SQLite file path. Usually leave unset and use CAP_DATA_DIR.
# CAP_DB_PATH=/data/cap.db

# Optional log path. Hosted default is CAP_DATA_DIR/cap-launch.log.
# CAP_LOG_PATH=/data/cap-launch.log

# Prevent the local browser/app window from opening.
# CAP_NO_OPEN=1
